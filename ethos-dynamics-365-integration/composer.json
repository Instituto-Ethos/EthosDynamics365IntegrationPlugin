{
    "name": "hacklab/ethos-dynamics-365-integration",
    "description": "Plugin para conectar Dynamics 365 com WordPress.",
    "type": "wordpress-plugin",
    "require": {
        "alexacrm/dynamics-webapi-toolkit": "v4.x-dev",
        "snicco/better-wp-cache": "dev-master",
        "cweagans/composer-patches": "dev-main"
    },
    "license": "GPL-2.0",
    "autoload": {
        "psr-4": {
            "EthosDynamics365Integration\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "extra": {
        "patches": {
            "alexacrm/dynamics-webapi-toolkit": {
                "Fix NullCacheItem compatibility with psr/cache 1.x": "patches/nullcacheitem-psr6-v1-compat.patch"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "cweagans/composer-patches": true
        }
    }
}
